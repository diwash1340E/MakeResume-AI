{
  "manifest_version": 3,
  "name": "MakeResume",
  "version": "1.0.0",
  "description": "Tailor your resume to job descriptions using AI.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Open MakeResume"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}